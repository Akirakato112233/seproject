# Copy this file to .env and fill in your values. Do not commit .env.

# Longdo Map API key (for map/location features)
EXPO_PUBLIC_LONGDO_MAP_API_KEY=your_longdo_map_api_key

# Supabase project URL and anon key (for profile photo storage)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
