{
  "name": "laundry-backend",
  "version": "1.0.0",
  "description": "Backend API for Laundry App",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node src/scripts/seedData.ts",
    "seed-users": "ts-node src/scripts/seedUsers.ts",
    "seed-orders": "ts-node src/scripts/seedOrders.ts",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "mongoose": "^7.5.0",
    "multer": "^2.1.0",
    "nodemailer": "^7.0.13",
    "puppeteer": "^24.36.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "twilio": "^5.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.5.0",
    "@types/nodemailer": "^7.0.9",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
