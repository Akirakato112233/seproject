# Copy this file to .env and fill in real values. Do not commit .env.
# -----------------------------------------------------------------------------

# Server
PORT=3000

# Database (required)
MONGODB_URI=mongodb://localhost:27017/laundry

# Google OAuth (required if using Google login)
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# In development, use ngrok to expose the backend. Set this to your ngrok URL
# (e.g. https://xxxx.ngrok-free.dev) so OAuth callback and CORS work.
NGROK_URL=https://your-ngrok-url.ngrok-free.dev

# Optional: JWT signing secret (use a strong value in production)
JWT_SECRET=your_jwt_secret_here

# Optional: OTP generation secret
OTP_SECRET=your_otp_secret_here

# Optional: Email (SMTP) for sending OTP or notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
MAIL_FROM=noreply@example.com

# Optional: Node environment (development | production)
NODE_ENV=development
